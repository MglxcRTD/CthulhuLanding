---
import "../styles/global.css";
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cthulhu: The Cosmic Abyss | Official Site</title>
  </head>
  <body class="text-white antialiased selection:bg-abyss-teal selection:text-white">
    
    <div class="fixed inset-0 z-0 pointer-events-none overflow-hidden bg-[#000d0c]">
      <div class="absolute top-[-20%] left-[-10%] w-[70%] h-[70%] bg-abyss-teal/40 blur-[120px] rounded-full animate-deep-pulse"></div>
      <div class="absolute bottom-[-20%] right-[-10%] w-[60%] h-[60%] bg-abyss-teal/30 blur-[120px] rounded-full animate-deep-pulse" style="animation-delay: 3s;"></div>
      <div class="absolute top-[40%] left-[60%] w-[40%] h-[40%] bg-abyss-light/15 blur-[100px] rounded-full animate-deep-pulse" style="animation-delay: 5s;"></div>
      
      <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(2,115,94,0.25)_1px,transparent_1px),linear-gradient(to_bottom,rgba(2,115,94,0.25)_1px,transparent_1px)] bg-[size:4rem_4rem] opacity-60 animate-pan-bg"></div>
      
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,rgba(132,217,208,0.8)_1px,transparent_1px)] bg-[size:3rem_3rem] opacity-40 animate-drift"></div>
      
      <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_0%,rgba(0,13,12,0.4)_100%)]"></div>
    </div>

    <div class="fixed inset-0 z-[100] pointer-events-none mix-blend-overlay opacity-20 bg-[url('https://grainy-gradients.vercel.app/noise.svg')]"></div>
    
    <main class="relative z-10 main-container">
      <slot />
    </main>

  </body>
</html>

<style is:global>
  html, body {
    margin: 0;
    padding: 0;
    width: 100%;
    background-color: #000d0c;
  }

  .main-container {
    width: 100%;
    overflow-x: hidden;
    display: flex;
    flex-direction: column;
    gap: 0;
    /* Eliminamos el line-height 0 que puede causar problemas con el renderizado de cajas */
  }
  
  /* ESTO ARREGLA EL CORTE: Todas las secciones son transparentes por defecto */
  section {
    position: relative;
    width: 100%;
    display: flex;
    flex-direction: column;
    background-color: transparent !important;
    /* Quitamos el margen negativo que a veces crea solapamientos visuales feos */
    margin-bottom: 0; 
    /* MÁSCARA GLOBAL: Cinta de cristal con fundido del 10% al entrar y salir */
    mask-image: linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 10%, black 90%, transparent 100%);
  }

  /* Animación de las luces */
  @keyframes deep-pulse {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 0.6; transform: scale(1.1); }
  }
  .animate-deep-pulse {
    animation: deep-pulse 20s infinite ease-in-out;
  }

  /* Animación de la cuadrícula */
  @keyframes pan-bg {
    0% { background-position: 0 0; }
    100% { background-position: 0 4rem; }
  }
  .animate-pan-bg {
    animation: pan-bg 15s linear infinite;
  }

  /* Animación de partículas */
  @keyframes drift {
    0% { background-position: 0 0; }
    100% { background-position: 3rem 3rem; }
  }
  .animate-drift {
    animation: drift 25s linear infinite;
  }
</style>